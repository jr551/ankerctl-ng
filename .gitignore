# Binaries (root-level only, not cmd/ankerctl/ directory)
/ankerctl
/ankerctl-ng
/ankerctl.exe
/find_anker
*.exe
*.exe~
*.dll
*.so
*.dylib

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build and Tooling
bin/
obj/
dist/
vendor/
!internal/web/static/vendor/
!internal/web/static/vendor/**

# Databases
*.db
*.db-journal
*.db-shm
*.db-wal

# Logs
logs/
*.log
ankerctl.log

# Local/Agent configs
.claude/
.gemini/
.env
.env.local
.env.*.local
# Local deployment/host docs (contain private IPs, paths, creds)
nas.md

# Temporary files
tmp/
temp/
*.tmp
*.bak
*~

# Local artifacts that must never be published
# OAuth/login callback captures (contain short-lived auth codes/tokens)
callback?*
*code=*state=*
# Firmware blobs (large binaries, not part of source)
*.factory.bin
firmware*.bin
*.bin

# Secrets and local runtime config (contain auth tokens / mqtt keys / api keys)
config.json
login.json
login_cache.json
*.token
*.pem
*.key
.ankerctl/
.ankerctl-ng/
